# =========================
# Application
# =========================

APP_NAME=CRM-Copilot
APP_ENV=development
DEBUG=true


# =========================
# Database
# =========================

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/crm_copilot


# =========================
# JWT Authentication
# =========================

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

JWT_ISSUER=crm-copilot
JWT_AUDIENCE=crm-copilot-api

ACCESS_TOKEN_EXPIRE_MINUTES=15

# Spec default can be 30 days
REFRESH_TOKEN_TTL_SECONDS=2592000


# =========================
# AI Providers
# =========================

OPENAI_API_KEY=
OR
ANTHROPIC_API_KEY=
OR
OPENROUTER_API_KEY=
